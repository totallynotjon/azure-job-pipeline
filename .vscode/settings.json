{
  "azureFunctions.projectSubpath": "functions/fn-pipeline",
  "azureFunctions.deploySubpath": "functions/fn-pipeline",
  "azureFunctions.projectLanguage": "Python",
  "azureFunctions.projectRuntime": "~4",
  "azureFunctions.projectLanguageModel": 2,
  "azureFunctions.preDeployTask": "pip install (production)",
  "azureFunctions.scmDoBuildDuringDeployment": false,
  "azureFunctions.coreToolsExecutablePath": "${env:HOME}/.local/bin/func",
  "azureFunctions.pythonVenv": ".venv",

  "terminal.integrated.env.linux": {
    "PATH": "${env:HOME}/.local/bin:${env:PATH}"
  },

  "azurite.location": "/tmp/azurite",
  "azurite.silent": true,
  "debug.internalConsoleOptions": "neverOpen",

  "files.exclude": {
    "**/.terraform": true,
    "**/__pycache__": true,
    "**/.venv": true
  },

  "python.defaultInterpreterPath": "${workspaceFolder}/functions/fn-pipeline/.venv/bin/python",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/functions/fn-pipeline"
  ],

  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "terraform.experimentalFeatures.prefillRequiredFields": true
}
