{
  "name": "fn-ingest-jobs",
  "version": "1.0.0",
  "description": "Timer-triggered Azure Function that ingests jobs from Adzuna and writes raw JSON to blob storage.",
  "main": "dist/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@azure/identity": "^4.4.0",
    "@azure/storage-blob": "^12.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
